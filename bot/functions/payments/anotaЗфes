import imaplib
import email

# Conexão com o servidor IMAP
imap_host = 'imap.gmail.com'
username = 'seuemail@gmail.com'
password = 'senha_app'  # Use senha de app se tiver 2FA

mail = imaplib.IMAP4_SSL(imap_host)
mail.login(username, password)
mail.select("inbox")

# Buscar emails não lidos com palavra "Pix"
status, messages = mail.search(None, '(UNSEEN SUBJECT "Pix recebido")')
for num in messages[0].split():
    status, data = mail.fetch(num, '(RFC822)')
    raw_email = data[0][1]
    msg = email.message_from_bytes(raw_email)

    assunto = msg["subject"]
    remetente = msg["from"]

    # Extrair corpo
    if msg.is_multipart():
        for part in msg.walk():
            if part.get_content_type() == "text/plain":
                corpo = part.get_payload(decode=True).decode()
    else:
        corpo = msg.get_payload(decode=True).decode()

    print("Remetente:", remetente)
    print("Assunto:", assunto)
    print("Corpo:", corpo)

